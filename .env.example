# ---------------------------------------------------------------------------
# Google OAuth2 — used ONLY to log users in (identity).
# Console: https://console.cloud.google.com/apis/credentials
#   * Create credentials -> OAuth client ID -> Web application
#   * Authorized redirect URIs -> add the GOOGLE_REDIRECT_URI below (exact match)
#   * (Configure the OAuth consent screen first if prompted.)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Signs the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Comma-separated Google account emails that can edit the default game rooms.
ADMIN_EMAILS=rishvanrv7@gmail.com

# Voice is peer-to-peer WebRTC. Signaling runs over Ably (browser <-> Ably), so
# it works on serverless hosts like Vercel. Create a free app at
# https://ably.com and paste its API key here. REQUIRED for voice to work.
ABLY_API_KEY=your_ably_api_key

# Public STUN is always used. WITHOUT TURN, calls connect only between peers on
# the same network — across mobile/strict/symmetric NATs they fail. Set these to
# hand a TURN relay to clients via /api/ice. Get them from a managed provider
# (e.g. Cloudflare Calls, Twilio, Metered, Xirsys) or your own coturn server.
# TURN_URLS is comma-separated, e.g.:
#   turn:turn.example.com:3478,turns:turn.example.com:5349?transport=tcp
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# ---------------------------------------------------------------------------
# MongoDB — stores user-created rooms. A node-cron job (instrumentation.ts)
# deletes expired rooms every minute. Local: mongodb://127.0.0.1:27017
# Atlas:  mongodb+srv://user:pass@cluster.xxxx.mongodb.net
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=allundo

# Optional: protect /api/cron/prune if you also trigger it from an external
# scheduler (e.g. Vercel Cron). Leave blank to allow unauthenticated calls.
CRON_SECRET=
